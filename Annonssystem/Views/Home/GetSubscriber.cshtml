@model AFI_Lab1.Models.CreateAdViewModel

<h2>Create ad for subscriber</h2>

<form asp-action="CreateAd" method="post">
    <input asp-for="SubscriptionNumber" type="hidden" />

    <div asp-validation-summary="All" style="color:red;"></div>

    <div>
        <label>First name:</label>
        <input asp-for="FirstName" />
        <span asp-validation-for="FirstName" style="color:red;"></span>
    </div>

    <div>
        <label>Last name:</label>
        <input asp-for="LastName" />
        <span asp-validation-for="LastName" style="color:red;"></span>
    </div>

    <div>
        <label>Phone number:</label>
        <input asp-for="PhoneNumber" />
        <span asp-validation-for="PhoneNumber" style="color:red;"></span>
    </div>

    <div>
        <label>Address:</label>
        <input asp-for="DeliveryAddress" />
        <span asp-validation-for="DeliveryAddress" style="color:red;"></span>
    </div>

    <div>
        <label>Postal code:</label>
        <input asp-for="PostalCode" />
        <span asp-validation-for="PostalCode" style="color:red;"></span>
    </div>

    <div>
        <label>City:</label>
        <input asp-for="City" />
        <span asp-validation-for="City" style="color:red;"></span>
    </div>

    <hr />

    <div>
        <label>Ad title:</label>
        <input asp-for="Title" />
        <span asp-validation-for="Title" style="color:red;"></span>
    </div>

    <div>
        <label>Ad content:</label>
        <textarea asp-for="Content"></textarea>
        <span asp-validation-for="Content" style="color:red;"></span>
    </div>

    <div>
        <label>Item price:</label>
        <input asp-for="ItemPrice" type="number" />
        <span asp-validation-for="ItemPrice" style="color:red;"></span>
    </div>

    <div>
        <label>Ad price:</label>
        <input asp-for="AdPrice" readonly />
    </div>

    <button type="submit">Create ad</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}